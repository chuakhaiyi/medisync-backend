# ─── MediSync+ Backend Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://medisync:changeme@localhost:5432/medisync_db?schema=public"

# ── Security ──────────────────────────────────────────────────────────────────
# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_BYTE_HEX_SECRET"
JWT_EXPIRES_IN="8h"

# AES-256-GCM encryption key for PHI fields (must be exactly 64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY="REPLACE_WITH_64_CHAR_HEX_KEY"

# ── AI (same provider as the Android app — Groq, OpenAI-compatible) ───────────
# These must match BuildConfig.LLM_* values in the Android app's build.gradle.kts
LLM_BASE_URL="https://api.groq.com/openai/v1"
LLM_API_KEY="gsk_REPLACE_WITH_YOUR_GROQ_KEY"
LLM_MODEL="llama-3.3-70b-versatile"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max API requests per 15-minute window per IP
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the hospital dashboard UI
ALLOWED_ORIGINS="http://localhost:5173,https://dashboard.medisync.hospital"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info


DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"